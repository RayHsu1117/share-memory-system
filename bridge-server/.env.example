# Postgres connection string (required).
# On Railway: add a Postgres database to the project, then reference it from
# the server service as ${{Postgres.DATABASE_URL}} (or use the auto-injected
# variable if you provisioned via the service settings).
# Local dev example (docker):
#   docker run --rm -d --name bridge-pg -e POSTGRES_PASSWORD=test -p 5433:5432 postgres:16
DATABASE_URL=postgres://postgres:test@localhost:5433/postgres

# Fixed API key protecting the server (required). Every MCP request must send
# `Authorization: Bearer <this value>`. Generate a long random secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BRIDGE_AUTH_TOKEN=change-me-to-a-long-random-secret

# HTTP port (optional). Railway injects PORT automatically; the default for
# local runs is 8787.
# PORT=8787

# ---------------------------------------------------------------------------
# OAuth 2.1 (optional — required for the claude.ai custom-connector flow).
# If OAUTH_SIGNING_SECRET or OAUTH_OWNER_PASSWORD is missing, the server still
# boots but ALL OAuth/discovery endpoints are disabled (static token only).
# ---------------------------------------------------------------------------

# Externally reachable origin of this server, no trailing slash. Used as the
# OAuth issuer and in discovery metadata; behind a proxy (Railway) request
# headers can't be trusted, so it must be set explicitly. Defaults to
# http://localhost:<PORT> which is only correct for local development.
# PUBLIC_BASE_URL=https://your-app.up.railway.app

# HMAC key used to hash OAuth codes/tokens at rest (never stored plaintext).
# Generate like BRIDGE_AUTH_TOKEN:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this value invalidates every issued OAuth token at once.
# OAUTH_SIGNING_SECRET=change-me-to-a-long-random-secret

# Password you (the owner) type into the /oauth/authorize approval page when
# connecting a new client such as claude.ai. Pick a strong passphrase.
# OAUTH_OWNER_PASSWORD=change-me-to-a-strong-passphrase
