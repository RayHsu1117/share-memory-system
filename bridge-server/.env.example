# Postgres connection string (required).
# On Railway: add a Postgres database to the project, then reference it from
# the server service as ${{Postgres.DATABASE_URL}} (or use the auto-injected
# variable if you provisioned via the service settings).
# Local dev example (docker):
#   docker run --rm -d --name bridge-pg -e POSTGRES_PASSWORD=test -p 5433:5432 postgres:16
DATABASE_URL=postgres://postgres:test@localhost:5433/postgres

# Fixed API key protecting the server (required). Every MCP request must send
# `Authorization: Bearer <this value>`. Generate a long random secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BRIDGE_AUTH_TOKEN=change-me-to-a-long-random-secret

# HTTP port (optional). Railway injects PORT automatically; the default for
# local runs is 8787.
# PORT=8787
